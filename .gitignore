# Bỏ qua thư mục chứa data (nhưng giữ lại cấu trúc thư mục thông qua .gitkeep)
data/*
!data/.gitkeep

# Bỏ qua các file weights nặng trong backend/weights
backend/weights/*.pt
backend/weights/*.pth
!backend/weights/.gitkeep

# Bỏ qua môi trường ảo và cache
venv/
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd

# Bỏ qua file cấu hình IDE (tùy chọn)
.vscode/
.idea/
*.swp

# Bỏ qua thư mục và file sinh ra bởi Next.js frontend
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.env*.local
.DS_Store

